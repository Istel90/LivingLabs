# LivingLabs local development environment
# Copy this file to `.env.local` on each development PC.
# Do not commit `.env.local`.

# Portal and internal tool URLs
VITE_INTERNAL_TOOLS_ORIGIN=http://127.0.0.1:5175
VITE_SURVEY_PLATFORM_URL=http://127.0.0.1:5174/
VITE_RESPONSIBLE_DEPARTMENT_TOOL_URL=http://127.0.0.1:5175/responsible-department
VITE_PRIORITY_MANAGEMENT_AREA_TOOL_URL=http://127.0.0.1:5175/priority-management-area
VITE_ADAPTATION_PATHWAY_TOOL_URL=http://127.0.0.1:5175/adaptation-pathway
VITE_PORTAL_TOOLS_URL=http://127.0.0.1:5173/tools#adaptation-support-tools
VITE_LEAD_DEPARTMENT_TOOL_URL=http://127.0.0.1:5173/lead-department-tool

# VWorld
# Use the key registered for the current PC/location.
VITE_VWORLD_API_KEY=YOUR_LOCAL_VWORLD_KEY
VITE_VWORLD_DOMAIN=http://127.0.0.1:5173/
VITE_VWORLD_PROXY_URL=http://127.0.0.1:5176/vworld-data

# Supabase shared inbox / handoff store
VITE_SUPABASE_URL=https://ehjygntjhqkddtcnvjdj.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
